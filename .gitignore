# =============================================================================
# Smart Document Q&A Agent - Git Ignore
# =============================================================================

# -----------------------------------------------------------------------------
# Environment & Secrets (NEVER commit these!)
# -----------------------------------------------------------------------------
.env
.env.local
.env.*.local
*.pem
secrets/

# -----------------------------------------------------------------------------
# Python
# -----------------------------------------------------------------------------
# Virtual environment
venv/
env/
.venv/

# Cache files
__pycache__/
*.py[cod]
*$py.class
*.so

# Distribution / packaging
build/
dist/
*.egg-info/
*.egg

# -----------------------------------------------------------------------------
# Vector Database (can be large, regenerated on load)
# -----------------------------------------------------------------------------
chroma_db/

# -----------------------------------------------------------------------------
# Data folder (may contain personal/test documents)
# -----------------------------------------------------------------------------
data/

# -----------------------------------------------------------------------------
# IDE & Editor
# -----------------------------------------------------------------------------
.idea/
.vscode/
*.swp
*.swo
*~
.DS_Store

# -----------------------------------------------------------------------------
# Claude Code temporary files
# -----------------------------------------------------------------------------
.claude/
tmpclaude-*

# -----------------------------------------------------------------------------
# Streamlit
# -----------------------------------------------------------------------------
.streamlit/

# -----------------------------------------------------------------------------
# Jupyter Notebooks (if any)
# -----------------------------------------------------------------------------
.ipynb_checkpoints/
*.ipynb

# -----------------------------------------------------------------------------
# Logs
# -----------------------------------------------------------------------------
*.log
logs/

# -----------------------------------------------------------------------------
# Testing
# -----------------------------------------------------------------------------
.pytest_cache/
.coverage
htmlcov/

# -----------------------------------------------------------------------------
# Task-specific markdown (keep README only)
# -----------------------------------------------------------------------------
Task*.md

# -----------------------------------------------------------------------------
# Personal documentation (not for public repo)
# -----------------------------------------------------------------------------
FLOW_EXPLANATION.md
